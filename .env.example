# PostgreSQL (local: docker compose, o URL de tu proveedor)
DATABASE_URL="postgresql://...:...@...:.../..."

PORT=3000

# NODE_ENV=production desactiva Swagger en /docs salvo que pongas ENABLE_SWAGGER=true
# ENABLE_SWAGGER=true

# IA: con USE_MOCK_AI=true o sin OPENAI_API_KEY se usa MockLlmProvider (sin costo)
USE_MOCK_AI=true
OPENAI_API_KEY=
# Opcional si usas OpenAI real
OPENAI_MODEL=gpt-4o-mini
