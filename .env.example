# PostgreSQL (local: docker compose, o URL de tu proveedor)
DATABASE_URL="postgresql://...:...@...:.../..."

PORT=3000

# NODE_ENV=production desactiva Swagger en /docs salvo que pongas ENABLE_SWAGGER=true
# ENABLE_SWAGGER=true

# Resúmenes: sin clave o USE_MOCK_AI=true → respuesta local
USE_MOCK_AI=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
